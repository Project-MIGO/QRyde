# QRyde environment configuration (Next.js — all client-visible vars must
# start with NEXT_PUBLIC_).
# Copy this file to `.env.local` and fill in real values for the demo.

# Stellar testnet endpoints (defaults are fine).
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Payment asset for fare settlement.
# Leave empty to use native XLM as a fallback for the demo.
# To use a real PHPC stablecoin, set both:
#   NEXT_PUBLIC_PAYMENT_ASSET_CODE=PHPC
#   NEXT_PUBLIC_PAYMENT_ASSET_ISSUER=G... (PHPC issuer public key on testnet)
# To use Circle's testnet USDC instead:
#   NEXT_PUBLIC_PAYMENT_ASSET_CODE=USDC
#   NEXT_PUBLIC_PAYMENT_ASSET_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
NEXT_PUBLIC_PAYMENT_ASSET_CODE=
NEXT_PUBLIC_PAYMENT_ASSET_ISSUER=
